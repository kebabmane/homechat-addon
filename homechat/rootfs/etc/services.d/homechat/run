#!/usr/bin/with-contenv bashio
# ==============================================================================
# Start HomeChat Rails application
# s6-overlay docs: https://github.com/just-containers/s6-overlay
# ==============================================================================

declare site_name
declare allow_signups
declare port
declare access_mode
declare ssl
declare certfile
declare keyfile
declare log_level
declare enable_integrations
declare auto_create_api_token
declare home_assistant_integration
declare network_range
declare discovery_mode
declare enable_nabu_casa
declare ingress_entry

bashio::log.info "Starting HomeChat..."

# Get configuration options
site_name=$(bashio::config 'site_name')
allow_signups=$(bashio::config 'allow_signups')
port=$(bashio::config 'port')
access_mode=$(bashio::config 'access_mode')
ssl=$(bashio::config 'ssl')
certfile=$(bashio::config 'certfile')
keyfile=$(bashio::config 'keyfile')
log_level=$(bashio::config 'log_level')
enable_integrations=$(bashio::config 'enable_integrations')
auto_create_api_token=$(bashio::config 'auto_create_api_token')
home_assistant_integration=$(bashio::config 'home_assistant_integration')
network_range=$(bashio::config 'network_range')
discovery_mode=$(bashio::config 'discovery_mode')
enable_nabu_casa=$(bashio::config 'enable_nabu_casa')

# Set environment variables
export RAILS_ENV=production
export RAILS_SERVE_STATIC_FILES=true
export RAILS_LOG_TO_STDOUT=true
export HOME_ASSISTANT_ADDON=true

# SSL Configuration based on access mode
# - ingress: HA handles SSL termination, we assume SSL from proxy headers
# - direct_ssl: Terminate SSL at Rails/Puma layer with certificates
# - direct_http: No SSL, plain HTTP (for local network only)
case "${access_mode}" in
    "ingress")
        bashio::log.info "Access mode: Home Assistant Ingress (SSL handled by HA)"
        export RAILS_ASSUME_SSL=true
        export RAILS_FORCE_SSL=false
        ingress_entry=$(bashio::addon.ingress_entry 2>/dev/null || true)
        if [[ -n "${ingress_entry}" && "${ingress_entry}" != "/" ]]; then
            ingress_entry="/${ingress_entry#/}"
            ingress_entry="${ingress_entry%/}"
            export RAILS_RELATIVE_URL_ROOT="${ingress_entry}"
            bashio::log.info "Ingress base path: ${RAILS_RELATIVE_URL_ROOT}"
        else
            export RAILS_RELATIVE_URL_ROOT=""
        fi
        ssl_enabled=false
        ;;
    "direct_ssl")
        bashio::log.info "Access mode: Direct SSL (certificates at /ssl)"
        export RAILS_ASSUME_SSL=false
        export RAILS_FORCE_SSL=false
        export RAILS_RELATIVE_URL_ROOT=""
        ssl_enabled=true
        # Validate certificate files exist
        if [[ ! -f "/ssl/${certfile}" ]]; then
            bashio::log.error "SSL certificate not found: /ssl/${certfile}"
            bashio::exit.nok "SSL certificate file missing"
        fi
        if [[ ! -f "/ssl/${keyfile}" ]]; then
            bashio::log.error "SSL key not found: /ssl/${keyfile}"
            bashio::exit.nok "SSL key file missing"
        fi
        bashio::log.info "Using SSL certificates: /ssl/${certfile}, /ssl/${keyfile}"
        ;;
    "direct_http")
        bashio::log.info "Access mode: Direct HTTP (no SSL - local network only)"
        export RAILS_ASSUME_SSL=false
        export RAILS_FORCE_SSL=false
        export RAILS_RELATIVE_URL_ROOT=""
        ssl_enabled=false
        ;;
    *)
        bashio::log.warning "Unknown access mode: ${access_mode}, defaulting to ingress"
        export RAILS_ASSUME_SSL=true
        export RAILS_FORCE_SSL=false
        export RAILS_RELATIVE_URL_ROOT=""
        ssl_enabled=false
        ;;
esac
# Generate or load persistent secret key (using cryptographically secure random)
if [[ ! -f "/data/secret_key_base" ]]; then
    openssl rand -hex 64 > /data/secret_key_base
    chmod 600 /data/secret_key_base
fi
export SECRET_KEY_BASE=$(cat /data/secret_key_base)

derive_ar_key() {
    ruby -ropenssl -e 'puts OpenSSL::HMAC.hexdigest("SHA256", ENV.fetch("SECRET_KEY_BASE"), ARGV.fetch(0))[0, 32]' "$1"
}

if [[ ! -f "/data/ar_encryption_primary_key" || ! -f "/data/ar_encryption_deterministic_key" || ! -f "/data/ar_encryption_key_derivation_salt" ]]; then
    if [[ -f "/data/production.sqlite3" ]]; then
        bashio::log.warning "ActiveRecord encryption keys missing; deriving legacy-compatible keys from existing SECRET_KEY_BASE"
        derive_ar_key "active_record_encryption_primary_key" > /data/ar_encryption_primary_key
        derive_ar_key "active_record_encryption_deterministic_key" > /data/ar_encryption_deterministic_key
        derive_ar_key "active_record_encryption_key_derivation_salt" > /data/ar_encryption_key_derivation_salt
    else
        bashio::log.info "Generating ActiveRecord encryption keys..."
        openssl rand -hex 32 > /data/ar_encryption_primary_key
        openssl rand -hex 32 > /data/ar_encryption_deterministic_key
        openssl rand -hex 32 > /data/ar_encryption_key_derivation_salt
    fi
    chmod 600 /data/ar_encryption_primary_key /data/ar_encryption_deterministic_key /data/ar_encryption_key_derivation_salt
fi

export AR_ENCRYPTION_PRIMARY_KEY=$(cat /data/ar_encryption_primary_key)
export AR_ENCRYPTION_DETERMINISTIC_KEY=$(cat /data/ar_encryption_deterministic_key)
export AR_ENCRYPTION_KEY_DERIVATION_SALT=$(cat /data/ar_encryption_key_derivation_salt)
export PORT="${port}"
export SITE_NAME="${site_name:-HomeChat}"
export ALLOW_SIGNUPS="${allow_signups:-false}"
export ENABLE_INTEGRATIONS="${enable_integrations:-true}"
export AUTO_CREATE_API_TOKEN="${auto_create_api_token:-false}"
export HOME_ASSISTANT_INTEGRATION="${home_assistant_integration:-true}"
export NETWORK_RANGE="${network_range:-}"

# Set Home Assistant specific environment variables
if bashio::supervisor.ping; then
    export SUPERVISOR_TOKEN="${SUPERVISOR_TOKEN}"
    export HOMEASSISTANT_URL="http://supervisor/core"

    # Detect Nabu Casa remote access if enabled
    if [[ "${enable_nabu_casa}" == "true" ]]; then
        bashio::log.info "Checking for Nabu Casa remote access..."

        # Query the Supervisor API for Nabu Casa status
        nabu_casa_url=""
        if bashio::api.supervisor GET /core/api/config true &>/dev/null; then
            # Try to get the external URL from HA config
            external_url=$(bashio::api.supervisor GET /core/api/config '.external_url // empty' 2>/dev/null || echo "")

            if [[ -n "${external_url}" && "${external_url}" == *"nabu.casa"* ]]; then
                nabu_casa_url="${external_url}"
                bashio::log.info "Nabu Casa URL detected"
            fi
        fi

        # Export Nabu Casa URL if found
        if [[ -n "${nabu_casa_url}" ]]; then
            export NABU_CASA_URL="${nabu_casa_url}"
            bashio::log.info "Remote access via Nabu Casa is available"
        else
            bashio::log.info "Nabu Casa not detected or not configured"
        fi
    fi
fi

# Configure discovery mode
# - auto: Enable mDNS on local network, also expose via Nabu Casa if available
# - local_only: Only mDNS discovery, no cloud/remote access
# - disabled: No discovery service at all
case "${discovery_mode}" in
    "auto")
        bashio::log.info "Discovery mode: auto (mDNS + Nabu Casa if available)"
        export DISCOVERY_MODE="local"
        export DISCOVERY_ENABLED="true"
        ;;
    "local_only")
        bashio::log.info "Discovery mode: local_only (mDNS only)"
        export DISCOVERY_MODE="local"
        export DISCOVERY_ENABLED="true"
        unset NABU_CASA_URL  # Don't expose Nabu Casa URL
        ;;
    "disabled")
        bashio::log.info "Discovery mode: disabled (no discovery)"
        export DISCOVERY_MODE="disabled"
        export DISCOVERY_ENABLED="false"
        ;;
    *)
        bashio::log.info "Discovery mode: auto (default)"
        export DISCOVERY_MODE="local"
        export DISCOVERY_ENABLED="true"
        ;;
esac

# Set log level for Rails
case "${log_level}" in
    "debug")
        export RAILS_LOG_LEVEL=debug
        ;;
    "info")
        export RAILS_LOG_LEVEL=info
        ;;
    "warning")
        export RAILS_LOG_LEVEL=warn
        ;;
    "error")
        export RAILS_LOG_LEVEL=error
        ;;
    *)
        export RAILS_LOG_LEVEL=info
        ;;
esac

bashio::log.info "Site Name: ${SITE_NAME}"
bashio::log.info "Allow Signups: ${ALLOW_SIGNUPS}"
bashio::log.info "Port: ${PORT}"
bashio::log.info "SSL: ${ssl}"
bashio::log.info "Log Level: ${log_level}"

# Ensure database exists
cd /app || bashio::exit.nok "Could not change to app directory"

# Setup persistent storage directory for Active Storage uploads
if [[ ! -d "/data/storage" ]]; then
    bashio::log.info "Creating persistent storage directory..."
    mkdir -p /data/storage
fi

# Symlink app storage to persistent data directory
if [[ -d "/app/storage" && ! -L "/app/storage" ]]; then
    # Move any existing files to persistent storage
    if [[ "$(ls -A /app/storage 2>/dev/null)" ]]; then
        bashio::log.info "Moving existing storage files to persistent location..."
        cp -rn /app/storage/* /data/storage/ 2>/dev/null || true
    fi
    rm -rf /app/storage
fi
if [[ ! -L "/app/storage" ]]; then
    ln -sf /data/storage /app/storage
    bashio::log.info "Linked /app/storage -> /data/storage"
fi

# Setup database if needed
if [[ ! -f "/data/production.sqlite3" ]]; then
    bashio::log.info "Setting up database..."
    export DATABASE_URL="sqlite3:///data/production.sqlite3"
    ./bin/rails db:prepare
else
    bashio::log.info "Database exists, running migrations..."
    export DATABASE_URL="sqlite3:///data/production.sqlite3"
    ./bin/rails db:migrate
fi

# Always run seeds to ensure admin user is created if needed
bashio::log.info "Running database seeds..."
./bin/rails db:seed

# Display admin credentials info if they exist (NOT the actual password for security)
if [[ -f "/data/admin_credentials.json" ]]; then
    bashio::log.info "🔐 Admin credentials available!"

    created_at=$(bashio::jq /data/admin_credentials.json '.created_at')

    bashio::log.info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    bashio::log.info "🚀 HOMECHAT ADMIN ACCESS"
    bashio::log.info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    bashio::log.info "👤 Username: See /data/admin_credentials.json"
    bashio::log.info "🔑 Password: See /data/admin_credentials.json"
    bashio::log.info "🕒 Created: ${created_at}"
    bashio::log.info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    bashio::log.info "⚠️  Please change this password after first login!"
    bashio::log.info "🌐 Access HomeChat at: http://homeassistant.local:${port}"
    bashio::log.info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
fi

# Auto-create API token for Home Assistant integration if enabled
if [[ "${auto_create_api_token}" == "true" && "${home_assistant_integration}" == "true" ]]; then
    bashio::log.info "Setting up Home Assistant integration..."
    ./bin/rails runner "
      # Create API token if it doesn't exist
      unless ApiToken.exists?(name: 'Home Assistant Addon')
        token = ApiToken.generate_for_integration('Home Assistant Addon')
        puts 'Created API token for Home Assistant integration'
        File.write('/data/home_assistant_api_token', token.token)
        File.chmod(0600, '/data/home_assistant_api_token')
        puts 'Token written to /data/home_assistant_api_token'
      end

      # Set integration settings
      Setting.set('home_assistant_enabled', true)
      Setting.set('api_enabled', true)
      Setting.set('webhook_base_url', ENV.fetch('WEBHOOK_BASE_URL', 'http://homeassistant.local:3000'))

      puts 'Home Assistant integration configured'
    " 2>/dev/null || bashio::log.warning "Failed to setup integration (this is normal on first run)"
fi

# Start the Rails server
bashio::log.info "Starting HomeChat server on port ${port}..."

if [[ "${ssl_enabled}" == "true" ]]; then
    bashio::log.info "Starting with SSL enabled..."
    # Start Puma directly with SSL configuration
    exec bundle exec puma -b "ssl://0.0.0.0:${port}?key=/ssl/${keyfile}&cert=/ssl/${certfile}" -e production
else
    exec ./bin/rails server -b 0.0.0.0 -p "${port}"
fi
